import { ChevronDown } from 'lucide-react';
import { motion } from 'motion/react';
import Navbar from './components/Navbar';
import BlogCard from './components/BlogCard';
import Footer from './components/Footer';
import { BLOG_POSTS } from './constants';

export default function App() {
  return (
    <div className="min-h-screen bg-surface">
      <Navbar />
      
      <main className="pt-32 pb-20 px-6 max-w-7xl mx-auto">
        <header className="mb-12 text-center md:text-left">
          <motion.span 
            initial={{ opacity: 0, x: -10 }}
            animate={{ opacity: 1, x: 0 }}
            className="font-manrope text-primary tracking-[0.2em] mb-3 block text-xs font-bold"
          >
            JOURNAL
          </motion.span>
          <motion.h1 
            initial={{ opacity: 0, y: 20 }}
            animate={{ opacity: 1, y: 0 }}
            transition={{ delay: 0.1 }}
            className="font-plus-jakarta text-4xl md:text-5xl font-extrabold text-on-surface max-w-2xl leading-[1.1] tracking-tight"
          >
            Perspective on living a balanced life.
          </motion.h1>
        </header>

        <div className="grid grid-cols-1 md:grid-cols-12 gap-6 md:gap-8">
          {/* Main featured post (Span 8) */}
          <BlogCard post={BLOG_POSTS[0]} layout="featured" />

          {/* Side post (Span 4) */}
          <BlogCard post={BLOG_POSTS[1]} layout="standard" />

          {/* Standard row 1 (Span 4, Span 8) */}
          <BlogCard post={BLOG_POSTS[2]} layout="standard" />
          <BlogCard post={BLOG_POSTS[3]} layout="wide" />

          {/* Standard row 2 (Span 4, Span 4, Span 4) */}
          <BlogCard post={BLOG_POSTS[4]} layout="standard" />
          <BlogCard post={BLOG_POSTS[5]} layout="standard" />
          <BlogCard post={BLOG_POSTS[6]} layout="standard" />
        </div>

        <div className="flex justify-center mt-20">
          <motion.button 
            whileHover={{ scale: 1.05 }}
            whileTap={{ scale: 0.95 }}
            className="bg-primary-container text-on-primary-container hover:bg-primary transition-colors duration-300 px-10 py-4 rounded-full font-manrope font-bold tracking-wider shadow-lg flex items-center gap-2"
          >
            <span>LOAD MORE</span>
            <ChevronDown size={18} />
          </motion.button>
        </div>
      </main>

      <Footer />
    </div>
  );
}
